<!DOCTYPE html>
<html lang="ja">
<head>
  <link rel="manifest" href="manifest.json">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>あいろ</title>
  <link href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
  </style>
</head>
<body>
  <div class="container">
    <h1>あいろ</h1>
    <p class="subtitle">Art Insight Log</p>

    <div class="card">
      <label>日付</label>
      <input type="date" id="date">

      <label>展覧会名</label>
      <input type="text" id="exhibition" placeholder="展覧会名">

      <label>作家名</label>
      <input type="text" id="artist" placeholder="作家名">

      <label>タグ</label>

      <div id="tagButtons" class="tag-buttons">
        <button type="button" class="tag-btn" data-tag="美術">美術</button>
        <button type="button" class="tag-btn" data-tag="書道">書道</button>
        <button type="button" class="tag-btn" data-tag="舞台">舞台</button>
        <button type="button" class="tag-btn" data-tag="音楽">音楽</button>
        <button type="button" class="tag-btn" data-tag="映画">映画</button>
        <button type="button" class="tag-btn" data-tag="建築">建築</button>
        <button type="button" class="tag-btn" data-tag="工芸">工芸</button>
        <button type="button" class="tag-btn" data-tag="その他">その他</button>
      </div>

<style>
body {
  margin: 0;
  font-family: 'Zen Maru Gothic', sans-serif;
  background:
    linear-gradient(rgba(111,111,115,0.68), rgba(111,111,115,0.68)),
    url("./bg.png") repeat;
  background-size: 200px auto;
  background-attachment: fixed;
  color: #f8f8f8;
  padding: 20px;
}

.hidden {
  display: none;
}

#torineSection {
  margin-top: 4px;
  opacity: 0;
  transition: opacity 0.45s ease;
}

#torineSection.show {
  opacity: 1;
}

.torine-box {
  position: relative;
  border-radius: 16px;
  overflow: visible;
  border: 1px solid transparent;
  margin-top: 8px;
  margin-bottom: 16px;
  box-shadow:
    0 0 10px rgba(255, 210, 90, 0.10),
    inset 0 0 2px rgba(255, 255, 255, 0.10);
}

.torine-box::before {
  content: "";
  position: absolute;
  inset: 0;
  padding: 2px;
  border-radius: 18px;
  background:
    radial-gradient(circle at 8% 50%, rgba(255,255,255,0.95) 0 1.1px, transparent 2.4px),
    radial-gradient(circle at 22% 0%, rgba(255,245,210,0.9) 0 1px, transparent 2.2px),
    radial-gradient(circle at 46% 100%, rgba(255,255,255,0.92) 0 1.1px, transparent 2.3px),
    radial-gradient(circle at 78% 0%, rgba(255,235,170,0.88) 0 1px, transparent 2.2px),
    radial-gradient(circle at 100% 32%, rgba(255,255,255,0.95) 0 1.1px, transparent 2.4px),
    linear-gradient(
      120deg,
      rgba(212, 168, 58, 0.18) 0%,
      rgba(255, 244, 200, 0.95) 10%,
      rgba(255, 228, 120, 0.95) 22%,
      rgba(214, 170, 56, 1) 48%,
      rgba(255, 220, 110, 0.96) 72%,
      rgba(255, 250, 230, 0.92) 86%,
      rgba(212, 168, 58, 0.18) 100%
    );
  background-size:
    100% 100%,
    100% 100%,
    100% 100%,
    100% 100%,
    100% 100%,
    220% 220%;
  background-repeat: no-repeat;
  -webkit-mask:
    linear-gradient(#fff 0 0) content-box,
    linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  filter:
    drop-shadow(0 0 4px rgba(255, 190, 70, 0.35))
    drop-shadow(0 0 10px rgba(255, 230, 150, 0.18));
  pointer-events: none;
  z-index: 2;
}

.torine-box::after {
  content: "";
  position: absolute;
  inset: -22px;
  border-radius: 20px;
  pointer-events: none;
  z-index: 3;
  background:
    radial-gradient(circle at -10% 14%, rgba(255,239,170,0.85) 0 0.8px, transparent 1.6px),
    radial-gradient(circle at 18% 10%, rgba(255,244,190,0.78) 0 0.8px, transparent 1.7px),
    radial-gradient(circle at 42% 12%, rgba(255,239,170,0.82) 0 0.8px, transparent 1.6px),
    radial-gradient(circle at 78% 11%, rgba(255,239,170,0.82) 0 0.8px, transparent 1.6px),
    radial-gradient(circle at 110% 16%, rgba(226,185,72,0.8) 0 0.9px, transparent 1.8px),
    radial-gradient(circle at -9% 92%, rgba(226,185,72,0.82) 0 1px, transparent 2px),
    radial-gradient(circle at 34% 90%, rgba(212,168,58,0.78) 0 0.9px, transparent 1.8px),
    radial-gradient(circle at 54% 88%, rgba(255,244,190,0.78) 0 0.9px, transparent 1.8px),
    radial-gradient(circle at 78% 87%, rgba(212,168,58,0.78) 0 0.9px, transparent 1.8px),
    radial-gradient(circle at 109% 84%, rgba(226,185,72,0.8) 0 0.9px, transparent 1.8px),
    radial-gradient(circle at 72% 40%, rgba(255,244,190,0.9) 0 1.6px, transparent 3px),
    radial-gradient(circle at -4% 78%, rgba(226,185,72,0.88) 0 1.8px, transparent 3.2px),
    radial-gradient(circle at 12% 28%, rgba(255,239,170,0.55) 0 0.7px, transparent 1.4px),
    radial-gradient(circle at 52% 72%, rgba(255,244,190,0.5) 0 0.8px, transparent 1.5px),
    radial-gradient(circle at 80% 66%, rgba(226,185,72,0.48) 0 0.7px, transparent 1.4px);
  background-repeat: no-repeat;
  filter: brightness(1.05);
  animation: sparkle 2.6s ease-in-out infinite alternate;
  opacity: 0.78;
}

#torine {
  position: relative;
  z-index: 1;
  width: 100%;
  box-sizing: border-box;
  margin: 0;
  padding: 14px 16px;
  min-height: 110px;
  resize: vertical;
  line-height: 1.7;
  border: none;
  border-radius: 14px;
  background: rgba(255, 246, 210, 0.04);
  color: #ffffff;
  box-shadow: none;
  outline: none;
  font-size: 16px;
  font-family: 'Zen Maru Gothic', sans-serif;
}

#torine::placeholder {
  color: rgba(255,255,255,0.42);
}

@keyframes sparkle {
  0%, 100% {
    opacity: 0.35;
    filter: brightness(0.95) blur(0px);
  }
  50% {
    opacity: 0.78;
    filter: brightness(1.12) blur(0.12px);
  }
}
</style>


  <script>
  let currentPhoto = "";
  
  let selectedTag = "";

document.querySelectorAll(".tag-btn").forEach(btn => {
  btn.addEventListener("click", () => {
    document.querySelectorAll(".tag-btn").forEach(b => b.classList.remove("active"));
    btn.classList.add("active");
    selectedTag = btn.dataset.tag;
  });
});

document.getElementById("photo").addEventListener("change", function(e) {
  const file = e.target.files[0];

  if (!file) {
    currentPhoto = "";
    updatePhotoPreview("");
    return;
  }

  const reader = new FileReader();
  reader.onload = function(event) {
    currentPhoto = event.target.result;
    updatePhotoPreview(currentPhoto);
  };
  reader.readAsDataURL(file);
});

function updatePhotoPreview(src) {
  const wrap = document.getElementById("photoPreviewWrap");
  const img = document.getElementById("photoPreview");

  if (src) {
    img.src = src;
    wrap.classList.remove("hidden");
  } else {
    img.src = "";
    wrap.classList.add("hidden");
  }
}
  
    let logs = JSON.parse(localStorage.getItem("airoLogs")) || [];
    let selectedId = null;
    let editingId = null;

    function saveToStorage() {
      localStorage.setItem("airoLogs", JSON.stringify(logs));
    }

    function saveLog() {
      const date = document.getElementById("date").value;
      const exhibition = document.getElementById("exhibition").value;
      const artist = document.getElementById("artist").value;
      const tag = selectedTag;
      const felt = document.getElementById("felt").value;
      const analysis = document.getElementById("analysis").value;
      const torine = document.getElementById("torine").value.trim();
　  const photo = currentPhoto;


      if (!exhibition.trim()) {
        alert("展覧会名を入れてね。");
        return;
      }

      if (editingId) {
        const target = logs.find(log => log.id === editingId);
        if (target) {
          target.date = date;
          target.exhibition = exhibition;
          target.artist = artist;
          target.tag = tag;
          target.photo = photo;
          target.felt = felt;
          target.analysis = analysis;
          target.torine = torine;
        }
        selectedId = editingId;
      } else {
        const log = {
          id: Date.now(),
          date: date,
          exhibition: exhibition,
          artist: artist,
          tag: tag,
          photo: photo,
          felt: felt,
          analysis: analysis,
          torine: torine
        };
        logs.unshift(log);
        selectedId = log.id;
      }

      saveToStorage();
      clearForm();
      editingId = null;
      updateFormMode();
      renderLogs();

      if (selectedId) {
        showDetail(selectedId);
      }
    }
    
    
    document.addEventListener("DOMContentLoaded", function() {

  const editingFromLogs = localStorage.getItem("airoEditingId");

  if (editingFromLogs) {
    selectedId = Number(editingFromLogs);
    localStorage.removeItem("airoEditingId");
    startEdit();
  }

});

    
    function clearForm() {
  document.getElementById("date").value = "";
  document.getElementById("exhibition").value = "";
  document.getElementById("artist").value = "";
  document.getElementById("felt").value = "";
  document.getElementById("analysis").value = "";
  document.getElementById("torine").value = "";
  document.getElementById("photo").value = null;

  currentPhoto = "";
  updatePhotoPreview("");

  selectedTag = "";
  document.querySelectorAll(".tag-btn").forEach(btn => btn.classList.remove("active"));

  const torineSection = document.getElementById("torineSection");
  torineSection.classList.add("hidden");
  torineSection.classList.remove("show");

  document.getElementById("helpText").classList.add("hidden");
}
    

    function updateFormMode() {
      document.getElementById("saveButton").textContent = editingId ? "更新" : "保存";
      document.getElementById("cancelButton").classList.toggle("hidden", !editingId);
    }

    function getFilteredSortedLogs() {
      const sortOrder = document.getElementById("sortOrder").value;
      const filterTag = document.getElementById("filterTag").value;

      let result = [...logs];

      if (filterTag) {
        result = result.filter(log => log.tag === filterTag);
      }

      result.sort((a, b) => {
        return sortOrder === "new" ? b.id - a.id : a.id - b.id;
      });

      return result;
    }

    function renderLogs() {
      const logList = document.getElementById("logList");
      const filteredLogs = getFilteredSortedLogs().slice(0, 3);
      logList.innerHTML = "";

      if (filteredLogs.length === 0) {
        logList.innerHTML = "<p class='small'>まだ記録がありません。</p>";
        return;
      }

      filteredLogs.forEach(log => {
        const div = document.createElement("div");
        div.className = "log-item";
        div.onclick = function() {
          showDetail(log.id);
        };

const torineMain = document.createElement("div");
torineMain.className = "log-torine-main";

if (!log.torine || log.torine.trim() === "") {
  torineMain.textContent = "とりね中…";
  torineMain.classList.add("empty");
} else {
  torineMain.textContent = log.torine;
}

const subtitle = document.createElement("div");
subtitle.className = "log-subtitle";
subtitle.innerHTML =
  "<span>" + escapeHtml(log.exhibition || "") + "</span>" +
  ((log.date || log.tag)
    ? "<br>" + [
        escapeHtml(log.date || ""),
        log.tag ? "<span class='tag " + getTagClass(log.tag) + "'>" + escapeHtml(log.tag) + "</span>" : ""
      ].filter(Boolean).join(" / ")
    : ""
  );

div.appendChild(torineMain);
div.appendChild(subtitle);
        
        logList.appendChild(div);
      });
    }

    function showDetail(id) {
      const log = logs.find(item => item.id === id);
      if (!log) return;

      selectedId = id;

      const detailCard = document.getElementById("detailCard");
      const detailView = document.getElementById("detailView");

      detailView.innerHTML =
  (log.tag ? "<div class='tag " + getTagClass(log.tag) + "'>" + escapeHtml(log.tag) + "</div>" : "") +
  (log.torine
    ? "<div class='torine-hero'>" +
        "<div class='torine-hero-label'>とりね</div>" +
        "<div class='torine-hero-text'>" + escapeHtml(log.torine) + "</div>" +
      "</div>"
    : ""
  ) +
  makeDetailBlock("日付", log.date || "") +
  makeDetailBlock("展覧会名", log.exhibition || "") +
  makeDetailBlock("作家名", log.artist || "") +
  (log.photo ? "<div class='detail-block'><div class='detail-label'>画像</div><img src='" + log.photo + "' class='photo-preview' alt='保存画像'></div>" : "") +
  makeDetailBlock("感じたこと", log.felt || "") +
  makeDetailBlock("構造分析", log.analysis || "");
  

      detailCard.classList.remove("hidden");
    }
    
    function getTagClass(tag) {
  switch(tag) {
    case "美術": return "tag-art";
    case "書道": return "tag-calligraphy";
    case "舞台": return "tag-stage";
    case "音楽": return "tag-music";
    case "映画": return "tag-movie";
    case "建築": return "tag-architecture";
    case "工芸": return "tag-craft";
    default: return "tag-other";
  }
}

    function makeDetailBlock(label, value) {
      return (
        "<div class='detail-block'>" +
          "<div class='detail-label'>" + escapeHtml(label) + "</div>" +
          "<div>" + escapeHtml(value) + "</div>" +
        "</div>"
      );
    }
    
    function startEdit() {
  const log = logs.find(item => item.id === selectedId);
  if (!log) return;

  editingId = log.id;
  document.getElementById("date").value = log.date || "";
  document.getElementById("exhibition").value = log.exhibition || "";
  document.getElementById("artist").value = log.artist || "";
  document.getElementById("felt").value = log.felt || "";
  document.getElementById("analysis").value = log.analysis || "";
  document.getElementById("torine").value = log.torine || "";

  currentPhoto = log.photo || "";
  updatePhotoPreview(currentPhoto);

  selectedTag = log.tag || "";
  document.querySelectorAll(".tag-btn").forEach(btn => {
    btn.classList.toggle("active", btn.dataset.tag === selectedTag);
  });

  const torineSection = document.getElementById("torineSection");
  torineSection.classList.remove("hidden");

  requestAnimationFrame(() => {
    torineSection.classList.add("show");
  });

  updateFormMode();
  window.scrollTo({ top: 0, behavior: "smooth" });
}



    
    function cancelEdit() {
      editingId = null;
      clearForm();
      updateFormMode();
    }

    function deleteLog() {
      if (!selectedId) return;

      const ok = confirm("この記録を削除する？");
      if (!ok) return;

      logs = logs.filter(log => log.id !== selectedId);
      saveToStorage();

      selectedId = null;
      editingId = null;
      clearForm();
      updateFormMode();
      document.getElementById("detailCard").classList.add("hidden");
      renderLogs();
    }

    function escapeHtml(text) {
      return String(text)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/\"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    updateFormMode();
    renderLogs();
    
    function toggleHelp() {
  const el = document.getElementById("helpText");
  el.classList.toggle("hidden");
}


function revealTorine() {
  const torineSection = document.getElementById("torineSection");
  torineSection.classList.remove("hidden");

  requestAnimationFrame(() => {
    torineSection.classList.add("show");
  });

  const torineInput = document.getElementById("torine");
  if (torineInput) {
    setTimeout(() => {
      torineInput.focus();
    }, 200);
  }
}
    
  </script>


</body>
</html>